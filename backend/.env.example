# Copy this file to .env for local dev, or set these as environment
# variables on your host (Render, etc). Never commit the real .env file.

# Postgres connection string in production. Leave unset to use local SQLite.
DATABASE_URL=

# Random secret for signing login tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Brevo API config for sending OTP verification emails, used instead of
# SMTP because Render's free tier blocks outbound SMTP ports. Get a free
# API key at https://app.brevo.com -> Settings -> SMTP & API -> API Keys.
# EMAIL_FROM must be a sender you've verified in your Brevo account.
# If BREVO_API_KEY is left unset, OTPs are printed to the server console
# instead (fine for local dev).
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Trankr

# Google Sign-In (recommended — avoids all the SMTP/deliverability issues
# above entirely, since Google verifies the email for you). Create one at
# https://console.cloud.google.com/apis/credentials -> Create Credentials ->
# OAuth client ID -> Web application. Add your frontend URL (e.g.
# http://localhost:8000 and your Render URL) under "Authorized JavaScript
# origins". Leave blank to disable the Google button and fall back to the
# email/OTP flow above.
GOOGLE_CLIENT_ID=

# Optional: restrict registration to specific email(s), comma-separated.
# Leave blank for an open instance (default — recommended if you're
# self-hosting your own copy rather than running the original owner's instance).
ALLOWED_EMAILS=

# Not read by the app itself — only relevant on Render. Pins the Python
# version if backend/runtime.txt isn't being picked up (e.g. Root Directory
# is misconfigured). Set as a Render environment variable, not in this file.
PYTHON_VERSION=3.11.9

# Optional: your own public deployed URL (e.g. your Render URL). If set, the
# app pings its own /health endpoint every 10 minutes from a background
# thread, which prevents Render's free-tier web service from spinning down
# after 15 minutes idle. Deliberately does NOT keep your Postgres provider
# (e.g. Neon) awake too — Neon's free tier has a monthly compute-hour cap,
# not just a spin-down, so forcing it to stay warm 24/7 burns through that
# cap in ~2-3 weeks instead of a full month. Neon's cold start (~0.5-2s) is
# fast enough that it's better left alone to scale to zero between real use.
# Leave SELF_URL blank to disable self-pinging entirely — recommended for
# local dev. Set as an environment variable on your host, not committed
# here, since it reveals your deployed instance's URL.
#
# WARNING: Render's free tier gives 750 instance-hours/month PER ACCOUNT,
# not per service. Enabling this keeps one service alive ~24/7 (~730
# hours), which only leaves headroom if this is the only free service on
# that Render account. Running another free web service on the same
# account alongside this will exceed 750 hours before the month resets.
SELF_URL=

# Optional: override the self-ping interval in seconds. Default is 600 (10
# minutes), safely under Render's 15-minute spin-down window. Only relevant
# if SELF_URL is set.
KEEP_ALIVE_INTERVAL_SECONDS=600
