# Copy this file to .env for local dev, or set these as environment
# variables on your host (Render, etc). Never commit the real .env file.

# Postgres connection string in production. Leave unset to use local SQLite.
DATABASE_URL=

# Random secret for signing login tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Brevo API config for sending OTP verification emails, used instead of
# SMTP because Render's free tier blocks outbound SMTP ports. Get a free
# API key at https://app.brevo.com -> Settings -> SMTP & API -> API Keys.
# EMAIL_FROM must be a sender you've verified in your Brevo account.
# If BREVO_API_KEY is left unset, OTPs are printed to the server console
# instead (fine for local dev).
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Trankr

# Optional: restrict registration to specific email(s), comma-separated.
# Leave blank for an open instance (default — recommended if you're
# self-hosting your own copy rather than running the original owner's instance).
ALLOWED_EMAILS=

# Not read by the app itself — only relevant on Render. Pins the Python
# version if backend/runtime.txt isn't being picked up (e.g. Root Directory
# is misconfigured). Set as a Render environment variable, not in this file.
PYTHON_VERSION=3.11.9
